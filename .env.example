# ============================================================
# .env.example — Required environment variables
# All values are intentionally blank.
# NEVER put real secrets here. Inject via GCP Secret Manager.
# ============================================================

# GCP Project Configuration (no secret — public project ID)
GCP_PROJECT_ID=
GCP_REGION=us-central1

# WIF Configuration (no secrets — public identifiers)
GCP_WORKLOAD_IDENTITY_PROVIDER=
GCP_SERVICE_ACCOUNT_EMAIL=

# Railway
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT=production

# Cloudflare (inject via Secret Manager — never commit token)
CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN → stored in GCP Secret Manager as: cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID → stored in GCP Secret Manager as: cloudflare-account-id

# n8n (all inject via Secret Manager)
N8N_HOST=
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_RUNNERS_ENABLED=false
# n8n ≥2.17.0 automated owner setup (no browser wizard required — see R-06)
N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
N8N_INSTANCE_OWNER_EMAIL=ops@yourdomain.com
N8N_INSTANCE_OWNER_FIRST_NAME=Instance
N8N_INSTANCE_OWNER_LAST_NAME=Owner
# N8N_INSTANCE_OWNER_PASSWORD_HASH → bcrypt hash stored in GCP Secret Manager as: n8n-admin-password-hash
# N8N_ENCRYPTION_KEY → stored in GCP Secret Manager as: n8n-encryption-key
# Admin email used by deployment workflows for n8n login (set as GitHub Actions variable N8N_ADMIN_EMAIL)
N8N_ADMIN_EMAIL=admin@yourdomain.com

# Telegram (inject via Secret Manager)
# TELEGRAM_BOT_TOKEN → stored in GCP Secret Manager as: telegram-bot-token
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# OpenRouter (inject via Secret Manager)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DAILY_BUDGET_USD=10
# OPENROUTER_MANAGEMENT_KEY → stored in GCP Secret Manager as: openrouter-management-key

# Linear (inject via Secret Manager)
LINEAR_MCP_SERVER=https://mcp.linear.app
# LINEAR_API_KEY → stored in GCP Secret Manager as: linear-api-key
# LINEAR_WEBHOOK_SECRET → stored in GCP Secret Manager as: linear-webhook-secret

# GitHub App (inject via Secret Manager)
# GITHUB_APP_ID → stored in GCP Secret Manager as: github-app-id
# GITHUB_APP_INSTALLATION_ID → stored in GCP Secret Manager as: github-app-installation-id
# GITHUB_APP_PRIVATE_KEY → stored in GCP Secret Manager as: github-app-private-key
